# ExAgora frontend environment
# Copy this file to `.env.local` and fill in the values.

# WalletConnect / Reown project ID — required for the WalletConnect (QR / mobile)
# option in the Connect Wallet modal. Get one for free at https://cloud.reown.com
# (formerly cloud.walletconnect.com). Injected browser wallets (EIP-6963) work
# without this; only WalletConnect needs it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
